# Base RPC endpoint
RPC_URL=https://mainnet.base.org

# The B20 token this server operates on.
# Defaults to $MEMO on Base mainnet if unset. Human-readable view: https://memogram.pages.dev
MEMO_TOKEN_ADDRESS=0xb20000000000000000000001bb894ff0c9e82bf3

# Signer key — ONLY needed for send_memo. Leave unset for read-only use.
# SECURITY: use a DEDICATED wallet that never holds meaningful funds.
# MEMO_PRIVATE_KEY=0x...

# Spend caps (send_memo). Strongly recommended whenever a key is set.
# Expressed in human token units; enforced in wei before each send.
#   MEMO_MAX_PER_SEND  max tokens allowed in a single send_memo call
#   MEMO_MAX_TOTAL     max cumulative tokens this process may send per run
# MEMO_MAX_PER_SEND=100
# MEMO_MAX_TOTAL=1000

# Optional: default start block for read_memos caller scans (e.g. the $MEMO deploy block)
# MEMO_FROM_BLOCK=
